        "data": {
          "$schema": "script",
          "script": {
            "language": "python",
            "code": "import json\n\n\ndef execute(node_id, node_data, context):\n    novel = context[\"novel\"]\n    volume = \"\"\n    chapters = []\n\n    for item in novel.get(\"toc\", []):\n        chapter_id = item.get(\"chapterId\")\n        if chapter_id:\n            chapters.append({\n                \"volume\": volume,\n                \"id\": chapter_id,\n                \"title\": (item.get(\"titleZh\") or item.get(\"titleJp\") or \"\").strip(),\n            })\n        else:\n            volume = (item.get(\"titleZh\") or item.get(\"titleJp\") or \"\").strip()\n\n    context[\"chapters\"] = chapters\n"
          }
        },
