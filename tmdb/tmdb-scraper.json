        },
        "data": {
          "$schema": "http",
          "url": "https://api.themoviedb.org/3/movie/{{id}}?api_key={{TMDB_API_KEY}}&language={{language}}&append_to_response=credits,release_dates",
          "headers": [
            {
              "key": "Accept",
              "value": "application/json"
            }
          ],
          "formatter": "{% set movie = response.text %}\n{\n  \"movies\": [\n    {\n      \"title\": {{ movie|jsonpath('$.title')|tojson }},\n      \"originaltitle\": {{ movie|jsonpath('$.original_title')|tojson }},\n      \"tagline\": {{ movie|jsonpath('$.tagline')|tojson }},\n      \"plot\": {{ movie|jsonpath('$.overview')|tojson }},\n      \"rating\": {{ movie|jsonpath('$.vote_average')|tojson }},\n      \"year\": {{ movie|jsonpath('$.release_date')|year }},\n      \"premiered\": {{ movie|jsonpath('$.release_date')|tojson }},\n      \"country\": {{ movie|jsonpath('$.origin_country')|join(\", \")|tojson }},\n      \"mpaa\": {{ movie|jsonpath_first('$.release_dates.results[?iso_3166_1==\"US\"].release_dates[?certification].certification')|tojson }},\n      \"tags\": [],\n      \"genres\": {{ movie|jsonpath_all('$.genres[*].name')|tojson }},\n      \"studios\": {{ movie|jsonpath_all('$.production_companies[*].name')|tojson }},\n      \"directors\": {{ movie|jsonpath_all('$.credits.crew[?job==\"Director\"].name')|tojson }},\n      \"writers\": {{ movie|jsonpath_all('$.credits.crew[?job==\"Writer\"].name')|tojson }},\n      \"credits\": [],\n      \"actors\": [\n{% for a in movie|jsonpath_all('$.credits.cast[*]') %}\n        {\n          \"name\": {{ a|jsonpath('$.name')|tojson }},\n          \"role\": {{ a|jsonpath('$.character')|tojson }},\n          \"thumb\": {{ 'https://image.tmdb.org/t/p/w185'|suffix(a|jsonpath('$.profile_path'))|tojson }}\n        },\n{% endfor %}  \n      ],\n      \"poster\": {{ 'https://image.tmdb.org/t/p/w342'|suffix(movie|jsonpath('$.poster_path'))|tojson }},\n      \"backdrop\": {{ 'https://image.tmdb.org/t/p/original'|suffix(movie|jsonpath('$.backdrop_path'))|tojson }}\n    }\n  ]\n}"
        },
