      {
        "id": "019dc736-beb6-76bf-99d0-6b9a1b55c2a3",
        "type": "node",
        "position": {
          "x": 2101,
          "y": -370
        },
        "data": {
          "$schema": "http",
          "url": "https://api.themoviedb.org/3/tv/{{id}}?api_key={{TMDB_API_KEY}}&language={{language}}&append_to_response=credits,content_ratings",
          "headers": [
            {
              "key": "Accept",
              "value": "application/json"
            }
          ],
          "formatter": "{% set tv = response.text %}\n{% set tv_name = tv|jsonpath('$.name') %}\n{% set s = tv|jsonpath_first('$.seasons[?season_number=='+season|string+']')|tojson %}\n{% set name = s|jsonpath('$.name') or tv_name %}\n{% set overview = s|jsonpath('$.overview') %}\n{% set air_date = s|jsonpath('$.air_date') %}\n{% set poster_path = s|jsonpath('$.poster_path') %}\n{% set vote_average = s|jsonpath('$.vote_average') %}\n{\n  \"series\": [\n    {\n      \"title\": {{ (name if name.startswith(tv_name) else tv_name + (' ' + name if season > 1 else ''))|tojson }},\n      \"originaltitle\": {{ tv|jsonpath('$.original_name')|tojson }},\n      \"tagline\": {{ tv|jsonpath('$.tagline')|tojson }},\n      \"plot\": {{ (overview if overview else tv|jsonpath('$.overview'))|tojson }},\n      \"rating\": {{ (vote_average if vote_average else tv|jsonpath('$.vote_average'))|tojson }},\n      \"year\": {{ (air_date if air_date else tv|jsonpath('$.first_air_date'))|year }},\n      \"premiered\": {{ (air_date if air_date else tv|jsonpath('$.first_air_date'))|tojson }},\n      \"country\": {{ tv|jsonpath('$.origin_country')|join(\", \")|tojson }},\n      \"mpaa\": {{ tv|jsonpath_first('$.content_ratings.results[?iso_3166_1==\"US\"].rating')|tojson }},\n      \"tags\": [],\n      \"genres\": {{ tv|jsonpath_all('$.genres[*].name')|tojson }},\n      \"studios\": {{ tv|jsonpath_all('$.production_companies[*].name')|tojson }},\n      \"directors\": {{ tv|jsonpath_all('$.credits.crew[?job==\"Director\"].name')|tojson }},\n      \"writers\": {{ tv|jsonpath_all('$.credits.crew[?job==\"Writer\"].name')|tojson }},\n      \"credits\": [],\n      \"actors\": [\n{% for a in tv|jsonpath_all('$.credits.cast[*]') %}\n        {\n          \"name\": {{ a|jsonpath('$.name')|tojson }},\n          \"role\": {{ a|jsonpath('$.character')|tojson }},\n          \"thumb\": {{ 'https://image.tmdb.org/t/p/w185'|suffix(a|jsonpath('$.profile_path'))|tojson }}\n        },\n{% endfor %}  \n      ],\n      \"poster\": {{ 'https://image.tmdb.org/t/p/w342'|suffix(poster_path if poster_path else tv|jsonpath('$.poster_path'))|tojson }},\n      \"backdrop\": {{ 'https://image.tmdb.org/t/p/original'|suffix(tv|jsonpath('$.backdrop_path'))|tojson }}\n    }\n  ]\n}"
