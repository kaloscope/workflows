          "$schema": "script",
          "script": {
            "language": "python",
            "code": "from urllib.parse import quote\n\n\ndef execute(node_id, node_data, context):\n    keyword = context.get(\"keyword\")\n    page_num = context.get(\"page_num\")\n    if keyword and (keyword := keyword.strip()):\n        path = f\"/search.php?searchtype=articlename&searchkey={quote(keyword.strip(), encoding='gbk')}\"\n        if page_num and page_num > 1:\n            path += f\"&page={page_num}\"\n    else:\n        path = \"/articlelist.php\"\n        if page_num and page_num > 1:\n            path += f\"?page={page_num}\"\n    context[\"path\"] = path\n\n"
          }
